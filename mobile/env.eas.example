# EAS secrets template — set these via EAS CLI:
# eas secret:create --scope project --name KEY --value "VALUE"
#
# DO NOT commit .env files. These are only for reference.

# API
EXPO_PUBLIC_API_URL=https://api.nftproxygamble.com

# Smart contract (deployed NFTProxyVoucher on Polygon mainnet)
EXPO_PUBLIC_CONTRACT_ADDRESS=0x<deployed contract address>

# WalletConnect
EXPO_PUBLIC_WC_PROJECT_ID=<WalletConnect Cloud project ID>

# Balance verification HMAC key (must match backend BALANCE_SIGNING_KEY)
# Derive as: node -e "const {createHmac} = require('crypto'); console.log(createHmac('sha256', JWT_SECRET).update('nfpg_balance_v1').digest('hex'))"
EXPO_PUBLIC_BALANCE_VERIFY_KEY=<64-char hex>

# Certificate pinning (from actual server cert — see docs/CERT_PINNING_ROTATION.md)
CERT_PIN_PRIMARY=<base64 SPKI SHA-256 of primary leaf cert>
CERT_PIN_BACKUP=<base64 SPKI SHA-256 of backup cert>
CERT_PIN_EXPIRY=2028-01-01
API_HOST=api.nftproxygamble.com
