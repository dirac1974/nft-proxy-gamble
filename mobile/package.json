{
  "name": "nft-proxy-gamble-mobile",
  "version": "0.3.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
