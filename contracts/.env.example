# Polygon Amoy testnet
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# Polygon mainnet (only used for production deploys; gated by CONFIRM_MAINNET=YES)
POLYGON_RPC=https://polygon-rpc.com

# Deployer / minter private key. Use a dedicated, low-balance key per docs/SECURITY.md.
# Do NOT commit a real key.
PRIVATE_KEY=

# Polygonscan API key for contract verification.
POLYGONSCAN_API_KEY=

# Optional: override the script's per-network USDC default with an explicit address.
# Useful for local mocks or if Circle relocates the testnet token.
USDC_ADDRESS=

# Mainnet deploy safety latch — must equal exactly YES to proceed against `--network polygon`.
CONFIRM_MAINNET=

# Gas reporter toggle.
REPORT_GAS=
GAS_REPORT_FILE=
