generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionState {
  ACTIVE
  AWAITING_DRAW
  CASHED_OUT
}

enum MintStatus {
  PENDING
  MINTING
  MINTED
  FAILED
}

enum TransactionType {
  IAP_PURCHASE
  GAME_WIN
  GAME_LOSS
  CASHOUT_MINT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

model User {
  id            String        @id @default(cuid())
  walletAddress String        @unique
  coinBalance   Int           @default(0)
  ageConfirmed  Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      GameSession[]
  nftVouchers   NFTVoucher[]
  iapReceipts   IAPReceipt[]
  transactions  Transaction[]
  analytics     UserAnalytics?
}

model GameSession {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  gameType       String       @default("jacks-or-better-9-6")
  betAmount      Int
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  state          SessionState @default(ACTIVE)
  hands          Json         @default("[]")
  totalPayout    Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  nftVoucher     NFTVoucher?
  transactions   Transaction[]

  @@index([userId, state])
}

model NFTVoucher {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  sessionId   String     @unique
  session     GameSession @relation(fields: [sessionId], references: [id])
  tokenId     String?
  coinBalance Int
  gameType    String
  txHash      String?
  mintStatus  MintStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  transactions Transaction[]
}

model IAPReceipt {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  platform       String
  receiptHash    String       @unique
  productId      String
  coinsGranted   Int
  onChainTxHash  String?      // Polygon tx hash of PurchaseCommitted event (null until batch flushes)
  createdAt      DateTime     @default(now())
  transaction    Transaction?
}

model UserAnalytics {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  // rolling 1-hour window counters (reset by analyticsService on each update)
  coinsAddedLastHour  Int     @default(0)
  cashoutsToday       Int     @default(0)
  handsLastHour       Int     @default(0)
  winsLastHour        Int     @default(0)
  // persistent lifetime counters
  totalCoinsAdded     Int     @default(0)
  totalCashoutsAllTime Int    @default(0)
  // risk assessment
  riskLevel           RiskLevel @default(LOW)
  riskFlags           String[]  @default([])
  lastEvaluatedAt     DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         TransactionType
  coinDelta    Int
  balanceAfter Int
  sessionId    String?
  session      GameSession?    @relation(fields: [sessionId], references: [id])
  nftVoucherId String?
  nftVoucher   NFTVoucher?     @relation(fields: [nftVoucherId], references: [id])
  iapReceiptId String?         @unique
  iapReceipt   IAPReceipt?     @relation(fields: [iapReceiptId], references: [id])
  createdAt    DateTime        @default(now())
}
