generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionState {
  ACTIVE
  AWAITING_DRAW
  CASHED_OUT
}

enum MintStatus {
  PENDING
  MINTING
  MINTED
  FAILED
}

enum TransactionType {
  IAP_PURCHASE
  GAME_WIN
  GAME_LOSS
  CASHOUT_MINT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

model User {
  id            String        @id @default(cuid())
  walletAddress String        @unique
  coinBalance   Int           @default(0)
  ageConfirmed  Boolean       @default(false)
  // Server-side admin authority (FABLE-2026-07 H-3). Admin access is decided by
  // this column, NEVER by a self-asserted JWT claim. Defaults false; granted only
  // out-of-band (DB/ops), so a forged or leaked token cannot self-elevate.
  isAdmin       Boolean       @default(false)
  // Per-user provably-fair server-seed chain (FABLE-2026-07 H-2). nextServerSeed
  // is the secret pre-image consumed by the NEXT session; nextServerSeedHash is
  // its published commitment. Committing the seed before the next clientSeed is
  // known removes the operator's ability to grind the deck. Nullable until the
  // chain is initialized (account creation or first session).
  nextServerSeed     String?
  nextServerSeedHash String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      GameSession[]
  nftVouchers   NFTVoucher[]
  iapReceipts   IAPReceipt[]
  transactions  Transaction[]
  analytics     UserAnalytics?
  adminActions  AdminAuditLog[]
}

// Append-only audit trail of privileged admin actions (FABLE-2026-07 H-3).
// Every mutating admin route writes one row here so admin activity is
// attributable and reviewable after the fact.
model AdminAuditLog {
  id           String   @id @default(cuid())
  adminUserId  String
  admin        User     @relation(fields: [adminUserId], references: [id])
  action       String   // e.g. "set-risk", "read-flagged-users"
  targetUserId String?  // subject of the action, when applicable
  detail       Json     @default("{}")
  ip           String?
  createdAt    DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId, createdAt])
}

model GameSession {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  gameType       String       @default("jacks-or-better-9-6")
  betAmount      Int
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  state          SessionState @default(ACTIVE)
  hands          Json         @default("[]")
  totalPayout    Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  nftVoucher     NFTVoucher?
  transactions   Transaction[]

  @@index([userId, state])
}

model NFTVoucher {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  sessionId   String     @unique
  session     GameSession @relation(fields: [sessionId], references: [id])
  tokenId     String?
  coinBalance Int
  gameType    String
  txHash      String?
  mintStatus  MintStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  transactions Transaction[]

  // /nfts route does `findMany({ where: { userId }, orderBy: { createdAt: 'desc' } })`
  // on every My-NFTs tab render. Compound index supports both filter and sort.
  @@index([userId, createdAt(sort: Desc)])
}

model IAPReceipt {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  platform       String
  receiptHash    String       @unique
  productId      String
  coinsGranted   Int
  onChainTxHash  String?      // Polygon tx hash of PurchaseCommitted event (null until batch flushes)
  createdAt      DateTime     @default(now())
  transaction    Transaction?
}

model UserAnalytics {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  // rolling 1-hour window counters (reset by analyticsService on each update)
  coinsAddedLastHour  Int     @default(0)
  cashoutsToday       Int     @default(0)
  handsLastHour       Int     @default(0)
  winsLastHour        Int     @default(0)
  // persistent lifetime counters
  totalCoinsAdded     Int     @default(0)
  totalCashoutsAllTime Int    @default(0)
  // risk assessment
  riskLevel           RiskLevel @default(LOW)
  riskFlags           String[]  @default([])
  lastEvaluatedAt     DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         TransactionType
  coinDelta    Int
  balanceAfter Int
  sessionId    String?
  session      GameSession?    @relation(fields: [sessionId], references: [id])
  nftVoucherId String?
  nftVoucher   NFTVoucher?     @relation(fields: [nftVoucherId], references: [id])
  iapReceiptId String?         @unique
  iapReceipt   IAPReceipt?     @relation(fields: [iapReceiptId], references: [id])
  createdAt    DateTime        @default(now())

  // Compound index for analyticsService rolling-window queries and the cashout
  // daily-limit count. Every game result and cashout triggers 4 filters on
  // (userId, type, createdAt) — without this index those are full table scans.
  @@index([userId, type, createdAt])
}
