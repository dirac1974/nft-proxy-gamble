# Backend environment variables — copy to .env and fill in values before running.

# PostgreSQL connection string (Docker Compose default shown).
# Supabase (production). Get password from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-DB-PASSWORD]@db.yzodntgnaydfkqvibmff.supabase.co:5432/postgres
# Local Docker fallback (development only):
# DATABASE_URL=postgresql://nftp:nftp_dev@localhost:5432/nft_proxy_gamble

# HTTP port for the Express server.
PORT=3000

# JWT secret — use a strong random value in production.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
# JWT expiry (e.g. 24h, 7d)
JWT_EXPIRY=14d

# Polygon Amoy RPC endpoint.
POLYGON_RPC=https://rpc-amoy.polygon.technology

# Backend hot wallet private key — this wallet must hold MINTER_ROLE on the contract.
# NEVER use a key holding mainnet funds. Fund with Amoy MATIC only.
MINTER_PRIVATE_KEY=REPLACE_WITH_MINTER_WALLET_PRIVATE_KEY

# Deployed NFTProxyVoucher contract address.
CONTRACT_ADDRESS=REPLACE_WITH_DEPLOYED_CONTRACT_ADDRESS

# Apple App Store shared secret for receipt validation.
# Obtain from App Store Connect > My Apps > App Information.
APPLE_SHARED_SECRET=REPLACE_WITH_APPLE_SHARED_SECRET

# Google Play service account JSON (base64-encoded).
# Obtain from Google Play Console > Setup > API access.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=REPLACE_WITH_BASE64_JSON

# Node environment: development | test | production
NODE_ENV=development
