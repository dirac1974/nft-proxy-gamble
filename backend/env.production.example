# Production environment template
# Copy to .env (never commit .env)
# All EAS secrets should be set via: eas secret:create --scope project --name KEY --value VALUE

DATABASE_URL=postgresql://USER:PASS@HOST:5432/nftproxygamble?sslmode=require
PORT=3000
JWT_SECRET=<64-char random hex — openssl rand -hex 32>
JWT_EXPIRY=24h

# Blockchain
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/<API_KEY>
MINTER_PRIVATE_KEY=<funded Polygon mainnet wallet private key — keep in secret manager>
CONTRACT_ADDRESS=<deployed NFTProxyVoucher address on mainnet>

# IAP
APPLE_SHARED_SECRET=<from App Store Connect → My Apps → In-App Purchases>
GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64 of service account JSON with Android Publisher API>

# Device Attestation
APPLE_APP_ATTEST_TEAM_ID=<10-char Apple Team ID>
APPLE_APP_ATTEST_BUNDLE_ID=com.nftproxygamble.app
GOOGLE_PLAY_INTEGRITY_PACKAGE=com.nftproxygamble.app
DEVICE_ATTESTATION_ENFORCE=false
# Set to true after 50+ shadow samples confirm coverage (see PHASE_3.6_SECURITY_HARDENING_CHECKLIST.md)

NODE_ENV=production
